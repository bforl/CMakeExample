{
    "version": 3,
    "configurePresets": [
        {
            "name": "x64-Debug",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "x64-Release",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ]
}
